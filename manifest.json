{
    "manifest_version": 3,
    "name": "ChatGPT Booster Ultra",
    "version": "1.4.6",
    "description": "Siêu tối ưu hóa ChatGPT với các kỹ thuật Ultra: Fetch Interception, Virtualization và GPU Acceleration.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://claude.ai/*",
                "*://gemini.google.com/*"
            ],
            "js": [
                "settingsBridge.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://claude.ai/*",
                "*://gemini.google.com/*"
            ],
            "js": [
                "fetchInterceptor.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://claude.ai/*",
                "*://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "ChatGPT Booster Ultra"
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "minimum_chrome_version": "110"
}
